{
  "info": {
    "name": "Ethiopian Heritage Trail API",
    "description": "API endpoints encompassing Identity, Landmark Management, Visits tracking, and Admin Analytics for the Heritage Trail system.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{API_BASE_URL}}/auth/login",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@heritage.et\",\n  \"password\": \"password123\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Landmarks",
      "item": [
        {
          "name": "List Landmarks",
          "request": {
            "method": "GET",
            "url": "{{API_BASE_URL}}/landmarks",
            "header": [ { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" } ]
          }
        },
        {
          "name": "Bulk QR ZIP",
          "request": {
            "method": "POST",
            "url": "{{API_BASE_URL}}/admin/landmarks/bulk-qr/zip",
            "header": [ { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" } ]
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Get Flow Data",
          "request": {
            "method": "GET",
            "url": "{{API_BASE_URL}}/analytics/flow",
            "header": [ { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" } ]
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "API_BASE_URL", "value": "http://localhost:9002/api/v1", "type": "string" },
    { "key": "ACCESS_TOKEN", "value": "placeholder.jwt.token", "type": "string" }
  ]
}
