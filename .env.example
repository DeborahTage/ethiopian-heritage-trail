# ──────────────────────────────────────
# Ethiopian Heritage Trail — Root .env
# Copy to .env and fill in real values
# ──────────────────────────────────────

# PostgreSQL
POSTGRES_DB=heritage_trail
POSTGRES_USER=heritage
POSTGRES_PASSWORD=heritage_secret
# Host port 5433 → container port 5432

# Redis (host 6380 → container 6379)
REDIS_PASSWORD=redis_secret

# MinIO (host 9002 → container 9000, host 9003 → console 9001)
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret_123

# Spring Boot
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=changeme_in_production_aabbccdd00112233aabbccdd00112233
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Firebase (FCM)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=/secrets/firebase-service-account.json
